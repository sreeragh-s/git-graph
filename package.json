{
  "name": "code-graph",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:cli": "cd packages/cli && npm run dev",
    "dev:web": "cd packages/web && npm run dev",
    "build": "npm run build --workspace=packages/cli && npm run build --workspace=packages/web",
    "analyze": "cd packages/cli && npm run analyze",
    "serve": "cd packages/cli && npm run serve"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
